      "purpose": "any"
    },
    {
      "src": "/public/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/public/icons/icon-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "shortcuts": [
    {
      "name": "Study Guide",
      "short_name": "Guide",
      "url": "/pages/study-guide.html",
      "icons": [{ "src": "/public/icons/shortcut-guide.png", "sizes": "96x96" }]
    },
    {
      "name": "Lessons",
      "short_name": "Lessons",
      "url": "/pages/lesson.html",
      "icons": [{ "src": "/public/icons/shortcut-lessons.png", "sizes": "96x96" }]
    }
  ],

  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "related_applications": [
    {
      "platform": "webapp",
