  "description": "A bilingual learning garden designed to help Ita study for her arborist certification with gentle lessons, quizzes, and beautiful nature-inspired visuals.",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#050b08",
  "theme_color": "#ff6b9c",
